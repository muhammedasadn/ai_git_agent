{
  "gemini": {
    "api_key": "",
    "model": "gemini-1.5-flash",
    "temperature": 0.2
  },
  "ollama": {
    "base_url": "http://localhost:11434",
    "model": "qwen2.5-coder:1.5b",
    "timeout": 120,
    "temperature": 0.2
  },
  "agent": {
    "auto_push": false,
    "auto_init": true,
    "interactive": false,
    "dry_run": false,
    "max_commits_per_run": 10,
    "watch_interval_seconds": 5,
    "batch_window_seconds": 300,
    "watch_debounce_seconds": 3
  },
  "validation": {
    "enabled": true,
    "fail_on_error": true,
    "cmake_build_dir": "build",
    "python_test_command": "python -m pytest --tb=short -q"
  },
  "git": {
    "default_branch": "main",
    "sign_commits": false
  },
  "logging": {
    "verbose": false,
    "unicode_symbols": false,
    "log_to_file": false,
    "log_file": "agent.log"
  }
}